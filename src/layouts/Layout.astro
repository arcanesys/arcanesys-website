---
import '../styles/global.css';

interface Props {
  title: string;
  lang: string;
  description?: string;
}

const { title, lang, description = 'Sovereign NixOS fleet management with built-in compliance for regulated Europe.' } = Astro.props;
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="preload" href="/fonts/fraunces-variable.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/lora-variable.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/jetbrains-mono-variable.woff2" as="font" type="font/woff2" crossorigin />
</head>
<body>
  <slot />
</body>
</html>
