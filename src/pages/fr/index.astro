---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.astro';
import MetricsBar from '../../components/MetricsBar.astro';
import CrisisGrid from '../../components/CrisisGrid.astro';
import Callout from '../../components/Callout.astro';
import SolutionSection from '../../components/SolutionSection.astro';
import ArchitectureDiagram from '../../components/ArchitectureDiagram.astro';
import CtaSection from '../../components/CtaSection.astro';
import Footer from '../../components/Footer.astro';
import { t } from '../../i18n/utils';

const lang = 'fr';
---

<Layout
  title="Arcanesys — Infrastructure souveraine pour l'Europe régulée"
  lang={lang}
  description="Gestion de flotte NixOS avec conformité intégrée. Reproductible. Auto-hébergé. Open source."
>
  <Hero lang={lang} />
  <MetricsBar lang={lang} />

  <section class="max-w-content mx-auto px-10 py-12">
    <div class="font-mono text-[10px] tracking-[4px] text-indigo uppercase mb-2">
      {t(lang, 'problem.label')}
    </div>
    <h2 class="font-display text-[2rem] font-black text-ink leading-tight tracking-tight mb-4">
      {t(lang, 'problem.title')}
    </h2>

    <CrisisGrid lang={lang} />

    <Callout>
      <Fragment set:html={t(lang, 'problem.callout').replace(/^([^:]+:)/, '<strong class="text-ink">$1</strong>')} />
    </Callout>

    <SolutionSection lang={lang} />
    <ArchitectureDiagram lang={lang} />
  </section>

  <CtaSection lang={lang} />
  <Footer lang={lang} />
</Layout>
