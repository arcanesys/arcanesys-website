---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.astro';
import MetricsBar from '../../components/MetricsBar.astro';
import CtaSection from '../../components/CtaSection.astro';
import Footer from '../../components/Footer.astro';
import { Content as PitchContent } from '../../content/fr/pitch.md';

const lang = 'fr';
---

<Layout
  title="Arcanesys — Infrastructure souveraine pour l'Europe régulée"
  lang={lang}
  description="Gestion de flotte NixOS avec conformité intégrée. Reproductible. Auto-hébergé. Open source."
>
  <Hero lang={lang} />
  <MetricsBar lang={lang} />

  <section class="prose" style="max-width: 820px; margin: 0 auto; padding: 48px 56px;">
    <PitchContent />
  </section>

  <CtaSection lang={lang} />
  <Footer lang={lang} />
</Layout>
