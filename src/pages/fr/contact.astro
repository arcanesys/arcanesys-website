---
import Layout from '../../layouts/Layout.astro';
import PageHeader from '../../components/PageHeader.astro';
import Footer from '../../components/Footer.astro';
import { t } from '../../i18n/utils';

const lang = 'fr';
const pathname = Astro.url.pathname;

const regimes = [
  'nis2_essential',
  'nis2_important',
  'dora',
  'iso',
  'anssi',
  'secnumcloud',
  'other',
  'unsure',
];
---

<Layout title="Contact - Arcanesys" lang={lang} description="Réservez un appel de 15 min. Parlez-nous de votre flotte, votre régime réglementaire, et ce que vous cherchez à résoudre. Réponse sous un jour ouvré.">
  <PageHeader
    lang={lang}
    pathname={pathname}
    titleKey="pageHeader.contact.title"
    subtitleKey="pageHeader.contact.subtitle"
  />

  <section class="max-w-prose mx-auto px-10 py-12">
    <div>
      <form
        name="contact"
        method="POST"
        data-netlify="true"
        netlify-honeypot="bot-field"
        action={`/${lang}/contact/thanks/`}
        class="space-y-5"
      >
        <input type="hidden" name="form-name" value="contact" />
        <input type="hidden" name="locale" value={lang} />
        <input type="hidden" name="topic" id="topic-hidden" value="" />

        <p class="hidden">
          <label>{t(lang, 'contactForm.honeypot')} : <input name="bot-field" /></label>
        </p>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
          <div>
            <label for="name" class="block font-mono text-xs tracking-[2px] uppercase text-muted mb-2">{t(lang, 'contactForm.name')} *</label>
            <input id="name" name="name" type="text" required class="w-full px-4 py-3 bg-paper-2 border border-paper-3 rounded font-body text-[0.95em] text-ink focus:border-indigo focus:outline-none" />
          </div>
          <div>
            <label for="email" class="block font-mono text-xs tracking-[2px] uppercase text-muted mb-2">{t(lang, 'contactForm.email')} *</label>
            <input id="email" name="email" type="email" required class="w-full px-4 py-3 bg-paper-2 border border-paper-3 rounded font-body text-[0.95em] text-ink focus:border-indigo focus:outline-none" />
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
          <div>
            <label for="org" class="block font-mono text-xs tracking-[2px] uppercase text-muted mb-2">{t(lang, 'contactForm.org')} *</label>
            <input id="org" name="org" type="text" required class="w-full px-4 py-3 bg-paper-2 border border-paper-3 rounded font-body text-[0.95em] text-ink focus:border-indigo focus:outline-none" />
          </div>
          <div>
            <label for="role" class="block font-mono text-xs tracking-[2px] uppercase text-muted mb-2">{t(lang, 'contactForm.role')} *</label>
            <input id="role" name="role" type="text" required class="w-full px-4 py-3 bg-paper-2 border border-paper-3 rounded font-body text-[0.95em] text-ink focus:border-indigo focus:outline-none" />
          </div>
        </div>

        <div>
          <label for="fleet_size" class="block font-mono text-xs tracking-[2px] uppercase text-muted mb-2">{t(lang, 'contactForm.fleet_size')} *</label>
          <input id="fleet_size" name="fleet_size" type="number" min="0" required class="w-full md:w-1/3 px-4 py-3 bg-paper-2 border border-paper-3 rounded font-body text-[0.95em] text-ink focus:border-indigo focus:outline-none" />
        </div>

        <div>
          <div class="block font-mono text-xs tracking-[2px] uppercase text-muted mb-2">
            {t(lang, 'contactForm.regime')}
            <span class="lowercase tracking-normal text-muted/70 ml-2">- {t(lang, 'contactForm.regime_help')}</span>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-2">
            {regimes.map((r) => (
              <label class="flex items-center gap-2 text-[0.92em] text-ink cursor-pointer">
                <input type="checkbox" name="regime[]" value={r} class="accent-indigo" />
                {t(lang, `contactForm.regime_${r}`)}
              </label>
            ))}
          </div>
        </div>

        <div>
          <label for="problem" class="block font-mono text-xs tracking-[2px] uppercase text-muted mb-2">
            {t(lang, 'contactForm.problem')}
            <span class="lowercase tracking-normal text-muted/70 ml-2">- {t(lang, 'contactForm.problem_help')}</span>
          </label>
          <textarea id="problem" name="problem" rows="4" class="w-full px-4 py-3 bg-paper-2 border border-paper-3 rounded font-body text-[0.95em] text-ink focus:border-indigo focus:outline-none"></textarea>
        </div>

        <div class="pt-2">
          <button type="submit" class="font-mono text-xs tracking-[1.5px] uppercase px-7 py-3.5 rounded bg-indigo text-paper hover:bg-indigo-hover hover:-translate-y-px transition-all inline-block">
            {t(lang, 'contactForm.submit')} →
          </button>
        </div>
      </form>

      <p class="text-[0.82em] text-muted mt-8 leading-relaxed">
        En soumettant ce formulaire, vous nous autorisez à vous contacter à l'email indiqué.
        Nous ne partageons pas vos données avec des tiers et ne conservons rien au-delà de ce
        qui est nécessaire pour répondre. Voir <a href={`/${lang}/legal/privacy/`}>Confidentialité</a>.
      </p>
    </div>
  </section>

  <script is:inline>
    (function () {
      var params = new URLSearchParams(location.search);
      var topic = params.get('topic');
      if (topic) {
        var hidden = document.getElementById('topic-hidden');
        if (hidden) hidden.value = topic;
        var problem = document.getElementById('problem');
        if (problem && !problem.value) {
          var hints = { pilot: '[Pilote] ', workshop: '[Atelier] ', vision: '[Trajectoire de confiance] ' };
          problem.value = hints[topic] || '';
          problem.focus();
        }
      }
    })();
  </script>

  <Footer lang={lang} />
</Layout>
