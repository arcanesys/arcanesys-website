---
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Sovereign NixOS fleet management with built-in compliance for regulated Europe." />
  <title>Arcanesys</title>
  <link rel="preload" href="/fonts/fraunces-variable.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/jetbrains-mono-variable.woff2" as="font" type="font/woff2" crossorigin />
  <style>
    @font-face {
      font-family: 'Fraunces';
      src: url('/fonts/fraunces-variable.woff2') format('woff2');
      font-weight: 300 900;
      font-style: normal;
      font-display: swap;
    }
    @font-face {
      font-family: 'JetBrains Mono';
      src: url('/fonts/jetbrains-mono-variable.woff2') format('woff2');
      font-weight: 400 600;
      font-style: normal;
      font-display: swap;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body { height: 100%; }

    body {
      font-family: 'Lora', Georgia, serif;
      background: #0a0e1a;
      color: #faf8f5;
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
      padding: 24px;
      position: relative;
      overflow: hidden;
    }

    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background:
        radial-gradient(ellipse 60% 50% at 50% 20%, rgba(55,48,163,0.10), transparent),
        radial-gradient(ellipse 35% 30% at 80% 70%, rgba(6,95,70,0.05), transparent);
      pointer-events: none;
    }

    body::after {
      content: '';
      position: fixed;
      inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='.03'/%3E%3C/svg%3E");
      pointer-events: none;
      z-index: 1000;
      opacity: 0.4;
    }

    .card {
      position: relative;
      max-width: 520px;
      text-align: center;
    }

    .brand {
      font-family: 'JetBrains Mono', monospace;
      font-size: 12px;
      letter-spacing: 4px;
      color: rgba(250,248,245,0.3);
      margin-bottom: 2rem;
      text-transform: uppercase;
    }

    h1 {
      font-family: 'Fraunces', serif;
      font-size: clamp(2.2rem, 5vw, 3.2rem);
      font-weight: 900;
      line-height: 1.05;
      letter-spacing: -1.5px;
      margin-bottom: 0.5rem;
    }

    .tagline {
      font-family: 'Lora', Georgia, serif;
      font-style: italic;
      font-size: 1.05rem;
      color: rgba(250,248,245,0.35);
      margin-bottom: 2.5rem;
    }

    .lang-row {
      display: flex;
      gap: 14px;
      justify-content: center;
      margin-bottom: 2rem;
    }

    .lang-btn {
      display: inline-block;
      padding: 13px 28px;
      font-family: 'JetBrains Mono', monospace;
      font-size: 11px;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      text-decoration: none;
      border-radius: 4px;
      transition: all 0.2s;
      min-width: 160px;
    }

    .lang-btn-primary {
      background: #3730a3;
      color: #faf8f5;
    }
    .lang-btn-primary:hover {
      background: #4338ca;
      transform: translateY(-1px);
    }

    .lang-btn-secondary {
      border: 1px solid rgba(250,248,245,0.18);
      color: rgba(250,248,245,0.5);
    }
    .lang-btn-secondary:hover {
      border-color: rgba(250,248,245,0.35);
      color: rgba(250,248,245,0.7);
    }

    .footer {
      font-family: 'JetBrains Mono', monospace;
      font-size: 10px;
      letter-spacing: 2px;
      color: rgba(250,248,245,0.15);
    }
    .footer a {
      color: rgba(55,48,163,0.6);
      text-decoration: none;
    }
  </style>
</head>
<body>
  <div class="card">
    <div class="brand">Arcanesys</div>
    <h1>Sovereign infrastructure<br>for regulated Europe</h1>
    <p class="tagline">NixOS fleet management with built-in compliance.</p>
    <div class="lang-row">
      <a href="/en/" class="lang-btn lang-btn-primary">English</a>
      <a href="/fr/" class="lang-btn lang-btn-secondary">Français</a>
    </div>
    <div class="footer">
      <a href="https://github.com/arcanesys">github.com/arcanesys</a> · <a href="mailto:contact@arcanesys.fr">contact@arcanesys.fr</a>
    </div>
  </div>
</body>
</html>
