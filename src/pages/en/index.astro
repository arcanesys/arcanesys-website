---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.astro';
import MetricsBar from '../../components/MetricsBar.astro';
import CtaSection from '../../components/CtaSection.astro';
import Footer from '../../components/Footer.astro';
import { Content as PitchContent } from '../../content/en/pitch.md';

const lang = 'en';
---

<Layout title="Arcanesys — Sovereign Infrastructure for Regulated Europe" lang={lang}>
  <Hero lang={lang} />
  <MetricsBar lang={lang} />

  <section class="prose" style="max-width: 820px; margin: 0 auto; padding: 48px 56px;">
    <PitchContent />
  </section>

  <CtaSection lang={lang} />
  <Footer lang={lang} />
</Layout>
