---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.astro';
import CtaSection from '../../components/CtaSection.astro';
import Footer from '../../components/Footer.astro';

const lang = 'en';
const pathname = Astro.url.pathname;

const crises = [
  {
    title: 'Configuration drift',
    accent: 'border-l-indigo',
    body: 'Imperative tools manage <em>desired</em> state. They cannot prove <em>actual</em> state. Drift is mathematically inevitable.',
    answer: 'Reproducible by construction. Each commit produces a content-addressed closure, identical on every host.',
  },
  {
    title: 'Sovereignty',
    accent: 'border-l-amber',
    body: 'US cloud control planes (Jamf, Intune, AWS SSM) put your deployment capability behind the Cloud Act, vendor pricing, and third-party availability.',
    answer: '100% self-hosted. Git forge, binary cache, control plane - all on your infrastructure. If we disappear, your fleet keeps running.',
  },
  {
    title: 'Bolted-on security',
    accent: 'border-l-emerald',
    body: 'EDR, SIEM, SBOM scanners are detection layers stacked on top of mutable systems. They surveil, they do not change what runs.',
    answer: 'Security emerges from the system model: hash-addressed Nix store, signed-artifact chain end-to-end, closure-hash quarantine, impermanence.',
  },
  {
    title: 'Compliance',
    accent: 'border-l-rose',
    body: 'NIS2, DORA, ISO 27001, ANSSI BP-028 require auditable evidence. Traditional stacks produce assertions, not proofs.',
    answer: 'Compliance as a release gate, not a scanner. The build refuses non-compliant closures; the auditor verifies the chain offline, without trusting us.',
  },
];
---

<Layout title="Arcanesys - Signed GitOps for NixOS fleets in regulated Europe" lang={lang} description="Independent EU practice. We build NixFleet, signed GitOps for NixOS fleets with NIS2, DORA, ISO 27001 and ANSSI BP-028 evidence as a side effect of operation. Pilots, audits, and advisory for regulated operators.">
  <Hero lang={lang} pathname={pathname} />

  <section class="max-w-content mx-auto px-10 py-14">
    <div class="text-center mb-9">
      <div class="font-mono text-xs tracking-[4px] text-indigo uppercase mb-2">Who runs this</div>
      <h2 class="font-display text-[clamp(1.4rem,2.4vw,1.8rem)] font-black text-ink leading-tight tracking-tight">
        A small EU practice. Two principals. Three public repositories.
      </h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <div>
        <div class="font-mono text-xs tracking-[3px] text-muted uppercase mb-2">Built</div>
        <p class="text-[0.92em] text-ink leading-relaxed">
          ~44,500 lines of Rust across nine crates. 22 production Nix modules.
          16 typed compliance controls across 4 frameworks. End-to-end fleet-harness scenarios from signed-roundtrip to auditor-chain.
        </p>
      </div>
      <div>
        <div class="font-mono text-xs tracking-[3px] text-muted uppercase mb-2">Engaged</div>
        <p class="text-[0.92em] text-ink leading-relaxed">
          Pilots, compliance audits, architecture advisory, custom development.
          Fixed-scope or by-the-day. EU based, no SaaS, every deployment on operator infrastructure.
        </p>
      </div>
      <div>
        <div class="font-mono text-xs tracking-[3px] text-muted uppercase mb-2">Upstream</div>
        <p class="text-[0.92em] text-ink leading-relaxed">
          Contributors to <a href="https://github.com/cloud-gouv/securix" class="text-indigo hover:text-indigo-hover">cloud-gouv/securix</a>
          (DINUM's hardened NixOS), nixpkgs, and the broader NixOS ecosystem. Public RFCs with falsifiable done-criteria.
        </p>
      </div>
    </div>
    <div class="text-center mt-9 flex flex-wrap justify-center gap-x-8 gap-y-3">
      <a href={`/${lang}/about/`} class="font-mono text-xs tracking-[1.5px] uppercase text-indigo hover:text-indigo-hover no-underline">
        About Arcanesys →
      </a>
      <a href={`/${lang}/services/`} class="font-mono text-xs tracking-[1.5px] uppercase text-indigo hover:text-indigo-hover no-underline">
        Services →
      </a>
    </div>
  </section>

  <section class="max-w-content mx-auto px-10 py-16 border-t border-paper-3">
    <div class="text-center mb-10">
      <div class="font-mono text-xs tracking-[4px] text-indigo uppercase mb-2">Four crises. One architecture.</div>
      <h2 class="font-display text-[clamp(1.6rem,3vw,2.2rem)] font-black text-ink leading-tight tracking-tight">
        Why standard tools fall short in regulated Europe
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      {crises.map((c) => (
        <div class:list={['bg-paper-2 border border-paper-3 p-6 border-l-[3px]', c.accent]}>
          <h3 class="font-display text-lg font-bold text-ink mb-2">{c.title}</h3>
          <p class="text-[0.92em] text-muted leading-relaxed mb-3" set:html={c.body} />
          <p class="text-[0.92em] text-ink leading-relaxed"><strong>NixFleet:</strong> {c.answer}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="bg-paper-2 border-y border-paper-3">
    <div class="max-w-prose mx-auto px-10 py-14">
      <div class="font-mono text-xs tracking-[4px] text-indigo uppercase mb-2 text-center">In one sentence</div>
      <h2 class="font-display text-[clamp(1.5rem,2.6vw,2rem)] font-black text-ink leading-tight tracking-tight text-center mb-6">
        Move your regulated workloads to a declarative substrate
      </h2>
      <p class="text-[1.05rem] leading-relaxed text-ink text-center">
        Keep the rest where it is. NixFleet places your regulated zone - 5 to 15 hosts
        that carry your NIS2 / DORA / ANSSI exposure - on a signed-artifact GitOps loop.
        Commit → CI signs → control plane verifies → agent verifies independently →
        activate with magic rollback. <strong>No signing keys in the control plane.</strong>
        Compromise of the CP is an outage, not a breach.
      </p>
      <div class="text-center mt-8">
        <a href={`/${lang}/product/`} class="link-button">
          See the signed GitOps loop →
        </a>
      </div>
    </div>
  </section>

  <section class="max-w-content mx-auto px-10 py-14">
    <div class="grid grid-cols-1 md:grid-cols-[1fr_1.25fr_1fr] gap-6 items-center">
      <a href={`/${lang}/compliance/`} class="group relative block bg-paper-2 border-2 border-paper-3 border-t-[4px] border-t-emerald p-6 pb-12 no-underline transition-all duration-200 hover:-translate-y-1 hover:border-emerald hover:bg-paper hover:shadow-xl">
        <div class="font-mono text-xs tracking-[3px] text-emerald uppercase mb-2">Compliance</div>
        <h3 class="font-display text-base font-bold text-ink mb-2">16 controls · 4 frameworks</h3>
        <p class="text-[0.88em] text-muted leading-relaxed">NIS2 Article 21 mapping, signed evidence per host, governance engine with per-rule exceptions.</p>
        <span class="absolute bottom-4 right-5 font-mono text-emerald opacity-0 group-hover:opacity-100 group-hover:translate-x-1 transition-all duration-200" aria-hidden="true">→</span>
      </a>
      <a href={`/${lang}/pilot/`} class="group relative block bg-paper-2 border-2 border-rose/40 border-t-[4px] border-t-rose p-6 md:px-8 md:py-12 pb-12 md:pb-16 no-underline transition-all duration-200 hover:-translate-y-1 hover:border-rose hover:bg-paper hover:shadow-2xl">
        <div class="font-mono text-xs tracking-[3px] text-rose uppercase mb-2">Pilot</div>
        <h3 class="font-display text-lg font-bold text-ink mb-2">3 months · 5–15 hosts · free</h3>
        <p class="text-[0.92em] text-muted leading-relaxed">Your regulated zone on a declarative substrate. Signed NIS2 evidence packet at month 3. Migration from Ansible / Puppet / Chef in scope.</p>
        <span class="absolute bottom-4 right-5 font-mono text-rose opacity-0 group-hover:opacity-100 group-hover:translate-x-1 transition-all duration-200" aria-hidden="true">→</span>
      </a>
      <a href={`/${lang}/services/`} class="group relative block bg-paper-2 border-2 border-paper-3 border-t-[4px] border-t-indigo p-6 pb-12 no-underline transition-all duration-200 hover:-translate-y-1 hover:border-indigo hover:bg-paper hover:shadow-xl">
        <div class="font-mono text-xs tracking-[3px] text-indigo uppercase mb-2">Services</div>
        <h3 class="font-display text-base font-bold text-ink mb-2">Pilots, audits, advisory, custom</h3>
        <p class="text-[0.88em] text-muted leading-relaxed">Four engagement shapes. Fixed-scope or by-the-day. EU based, no SaaS, no lock-in.</p>
        <span class="absolute bottom-4 right-5 font-mono text-indigo opacity-0 group-hover:opacity-100 group-hover:translate-x-1 transition-all duration-200" aria-hidden="true">→</span>
      </a>
    </div>
  </section>

  <CtaSection lang={lang} />
  <Footer lang={lang} />
</Layout>
