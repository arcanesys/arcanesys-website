---
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex" />
  <title>404 - Not found - Arcanesys</title>
  <link rel="preload" href="/fonts/fraunces-variable.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/jetbrains-mono-variable.woff2" as="font" type="font/woff2" crossorigin />
  <style>
    body {
      margin: 0;
      background: #0a0e1a;
      color: #faf8f5;
      font-family: 'Lora', Georgia, serif;
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
      padding: 24px;
      position: relative;
      overflow: hidden;
    }
    body::before {
      content: '';
      position: fixed; inset: 0;
      background: radial-gradient(ellipse 60% 50% at 50% 20%, rgba(55,48,163,0.10), transparent),
                  radial-gradient(ellipse 35% 30% at 80% 70%, rgba(6,95,70,0.05), transparent);
      pointer-events: none;
    }
    body::after {
      content: '';
      position: fixed; inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='.03'/%3E%3C/svg%3E");
      pointer-events: none;
      z-index: 1000;
      opacity: 0.4;
    }
    .card { position: relative; max-width: 560px; text-align: center; }
    .brand {
      font-family: 'JetBrains Mono', monospace;
      font-size: 12px;
      letter-spacing: 4px;
      color: rgba(250,248,245,0.7);
      margin-bottom: 2rem;
      text-transform: uppercase;
    }
    .code {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.85rem;
      color: rgba(250,248,245,0.75);
      letter-spacing: 1px;
      margin-bottom: 1.4rem;
    }
    h1 {
      font-family: 'Fraunces', serif;
      font-size: clamp(2rem, 4.5vw, 2.8rem);
      font-weight: 900;
      line-height: 1.1;
      letter-spacing: -1px;
      margin: 0 0 0.7rem 0;
    }
    .tagline {
      font-style: italic;
      font-size: 1rem;
      color: rgba(250,248,245,0.8);
      margin-bottom: 2.2rem;
    }
    .lang-row { display: flex; gap: 14px; justify-content: center; }
    .btn {
      display: inline-block;
      padding: 12px 28px;
      font-family: 'JetBrains Mono', monospace;
      font-size: 12px;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      text-decoration: none;
      border-radius: 4px;
      min-width: 160px;
      transition: all 0.2s;
    }
    .btn-primary { background: #3730a3; color: #faf8f5; }
    .btn-primary:hover { background: #4338ca; transform: translateY(-1px); }
    .btn-secondary { border: 1px solid rgba(250,248,245,0.30); color: rgba(250,248,245,0.75); }
    .btn-secondary:hover { border-color: rgba(250,248,245,0.55); color: rgba(250,248,245,0.95); }
  </style>
</head>
<body>
  <div class="card">
    <div class="brand">Arcanesys</div>
    <div class="code">404 - host not in fleet</div>
    <h1>This page is not part of the declared closure.</h1>
    <p class="tagline">Cette page n'est pas dans la closure déclarée.</p>
    <div class="lang-row">
      <a href="/en/" class="btn btn-primary">Back to English</a>
      <a href="/fr/" class="btn btn-secondary">Retour FR</a>
    </div>
  </div>
</body>
</html>
