---
import { t } from '../i18n/utils';

interface Props {
  lang: string;
}

const { lang } = Astro.props;

const frameworks = ['NIS2', 'DORA', 'ISO 27001', 'ANSSI BP-028'];

const solutions = [
  { titleKey: 'solution.nix_title', textKey: 'solution.nix_text' },
  { titleKey: 'solution.cp_title', textKey: 'solution.cp_text' },
  { titleKey: 'solution.agent_title', textKey: 'solution.agent_text' },
  { titleKey: 'solution.compliance_title', textKey: 'solution.compliance_text' },
];
---

<div id="solution" class="mt-12 pt-10 border-t border-paper-3">
  <div class="font-mono text-[10px] tracking-[4px] text-indigo uppercase mb-2">
    {t(lang, 'solution.label')}
  </div>
  <h2 class="font-display text-[2rem] font-black text-ink leading-tight tracking-tight mb-4">
    {t(lang, 'solution.title')}
  </h2>
  <p class="mb-3.5 max-w-prose">
    {t(lang, 'solution.intro')}
  </p>

  <div class="flex gap-2.5 my-4 flex-wrap">
    {frameworks.map((fw) => (
      <span class="font-mono text-[10px] tracking-[1px] px-3.5 py-1.5 border border-paper-3 bg-paper-2 text-muted">
        {fw}
      </span>
    ))}
  </div>

  <div class="grid grid-cols-2 gap-4 my-6">
    {solutions.map((s) => (
      <div class="py-4">
        <h3 class="font-display text-base font-bold text-indigo mb-1">
          {t(lang, s.titleKey)}
        </h3>
        <p class="text-[0.88em] text-muted leading-relaxed">
          {t(lang, s.textKey)}
        </p>
      </div>
    ))}
  </div>
</div>
