---
import { t } from '../i18n/utils';

interface Props {
  lang: string;
}

const { lang } = Astro.props;
---

<section class="bg-dark text-paper px-10 py-13 text-center mt-12">
  <h2 class="font-display text-[1.8rem] font-black text-paper mb-2">
    {t(lang, 'cta.title')}
  </h2>
  <p class="font-body italic text-paper/40 text-[0.95em] mb-7">
    {t(lang, 'cta.subtitle')}
  </p>
  <a href="mailto:contact@arcanesys.fr" class="font-mono text-[11px] tracking-[1.5px] uppercase px-7 py-3.5 rounded bg-indigo text-paper hover:bg-indigo-hover hover:-translate-y-px transition-all inline-block">
    {t(lang, 'cta.button')}
  </a>
</section>
