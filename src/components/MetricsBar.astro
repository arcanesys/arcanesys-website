---
import { t } from '../i18n/utils';

interface Props {
  lang: string;
}

const { lang } = Astro.props;

const metrics = [
  { value: t(lang, 'metrics.rollback_value'), label: t(lang, 'metrics.rollback_label'), color: 'text-indigo' },
  { value: t(lang, 'metrics.controls_value'), label: t(lang, 'metrics.controls_label'), color: 'text-emerald' },
  { value: t(lang, 'metrics.frameworks_value'), label: t(lang, 'metrics.frameworks_label'), color: 'text-amber' },
  { value: t(lang, 'metrics.license_value'), label: t(lang, 'metrics.license_label'), color: 'text-rose' },
];
---

<section class="bg-paper border-b border-paper-3">
  <div class="max-w-content mx-auto px-10 py-7 grid grid-cols-4 gap-5">
    {metrics.map((m) => (
      <div class="text-center p-4 bg-paper-2 border border-paper-3">
        <div class:list={['font-display text-[2em] font-black leading-none', m.color]}>
          {m.value}
        </div>
        <div class="font-mono text-[9px] tracking-[2px] text-muted mt-1.5 uppercase">
          {m.label}
        </div>
      </div>
    ))}
  </div>
</section>
